# Режим SQLite (run_local.py — переопределяет DATABASE_URL автоматически):
# DATABASE_URL=sqlite+aiosqlite:///./data/sppr.db

# Режим PostgreSQL + PostGIS (полная карта):
DATABASE_URL=postgresql+asyncpg://sppr:sppr_secret@localhost:5432/sppr
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
DEMO_USERS_ENABLED=true
ALLOW_REGISTRATION=true
AUTH_RATE_LIMIT=10/minute
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
COOKIE_SECURE=false

# Autoroad network planner (network-planner package)
AUTOROAD_NETWORK_INPROCESS=true
# AUTOROAD_NETWORK_SERVICE_URL=http://127.0.0.1:8080
AUTOROAD_NETWORK_SOLVER=geosteiner
# GEOSTEINER_BIN_DIR=C:\path\to\geosteiner\bin

# AI Assistant chat — Ollama (local, free) or LM Studio
# Ollama: ollama pull qwen2.5:7b && ollama serve
ASSISTANT_CHAT_ENABLED=true
ASSISTANT_LLM_BASE_URL=http://127.0.0.1:11434/v1
ASSISTANT_LLM_API_KEY=ollama
ASSISTANT_LLM_MODEL=qwen2.5:7b
# LM Studio alternative:
# ASSISTANT_LLM_BASE_URL=http://127.0.0.1:1234/v1
# ASSISTANT_LLM_API_KEY=lm-studio
# ASSISTANT_LLM_MODEL=
# Z.AI GLM-5.1 (cloud):
# ASSISTANT_LLM_BASE_URL=https://api.z.ai/api/paas/v4
# ASSISTANT_LLM_API_KEY=<your-z.ai-api-key>
# ASSISTANT_LLM_MODEL=glm-5.1
# OpenRouter (https://openrouter.ai/ — free models use :free suffix):
# ASSISTANT_LLM_BASE_URL=https://openrouter.ai/api/v1
# ASSISTANT_LLM_API_KEY=<your-openrouter-api-key>
# OpenRouter prod: pin a chat model — do NOT use openrouter/free (may route to content-safety).
# ASSISTANT_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free
# ASSISTANT_LLM_MAX_TOKENS=1024

# Assistant rate limits (per role, production)
# ASSISTANT_CHAT_RATE_LIMIT_VIEWER=10/minute
# ASSISTANT_CHAT_RATE_LIMIT_DEFAULT=20/minute
# ASSISTANT_CHAT_RATE_LIMIT_ADMIN=40/minute
# ASSISTANT_MCP_RATE_LIMIT_VIEWER=15/minute
# ASSISTANT_MCP_RATE_LIMIT_DEFAULT=30/minute
# ASSISTANT_MCP_RATE_LIMIT_ADMIN=60/minute
# ASSISTANT_CHAT_MAX_TOOL_ROUNDS_VIEWER=4
# ASSISTANT_CHAT_MAX_ROUTED_TOOLS=12

# Dev stdio MCP (Cursor only, not deployed to VM)
ASSISTANT_DEV_MCP_ENABLED=true
# ASSISTANT_DEV_MCP_DOMAIN_TOOLS=false
# ASSISTANT_DEV_MCP_USER_EMAIL=admin@test.ru
# ASSISTANT_DEV_MCP_REPO_ROOT=
