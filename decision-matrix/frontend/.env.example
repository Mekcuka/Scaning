# Backend API (optional; default /api/v1 via Vite proxy in dev — рекомендуется для cookies)
# Не задавайте VITE_API_URL в локальной разработке без необходимости.
# VITE_API_URL=http://127.0.0.1:8000/api/v1

# 3D map (MapLibre + Three.js, view-only). Docs: docs/features/map-3d-features.md
# VITE_MAP_3D_ENABLED=true
# Если в Windows (Переменные среды) задано VITE_MAP_3D_ENABLED=false — оно перекрывает .env;
# удалите системную переменную или перезапустите dev: $env:VITE_MAP_3D_ENABLED='true'; npm run dev
# MapTiler terrain (3D relief): https://cloud.maptiler.com/account/keys
# VITE_MAPTILER_KEY=your_maptiler_key
