# Steiner Network Planner — microservice configuration

APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Comma-separated origins, or * for all
CORS_ORIGINS=*

# GeoSteiner (optional; mount binaries into container)
GEOSTEINER_BIN_DIR=vendor/geosteiner/bin
GEOSTEINER_TIMEOUT_SEC=300

# Readiness probe: require SteinerPy (installed in Docker image by default)
REQUIRE_STEINERPY=true

# Windows only: MSYS2 MinGW runtime for GeoSteiner DLLs
MSYS2_ROOT=C:\msys64
