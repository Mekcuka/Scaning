# Backend runtime environment for production container.
#
# Frontend build (GitHub Pages) — NOT in this file; set in repo Settings -> Actions -> Variables:
#   VITE_API_URL=https://your-api.example/api/v1
#   VITE_MAP_3D_ENABLED=true
#   VITE_MAPTILER_KEY=<MapTiler key for 3D terrain>
# See DEPLOY.md section 1 and decision-matrix/frontend/.env.example for local dev.
#
# Local Postgres+PostGIS on the same VM (deploy/docker-compose.yml service "db"):
DATABASE_URL=postgresql+asyncpg://sppr:change-me@db:5432/sppr
SECRET_KEY=change-me-in-production
# Must be "production" on VM — /health returns this field (verify after deploy).
ENVIRONMENT=production
DEMO_USERS_ENABLED=false
ALLOW_REGISTRATION=true
AUTH_RATE_LIMIT=10/minute
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://your-domain.example,https://your-user.github.io
ALGORITHM=HS256
COOKIE_SECURE=true
REDIS_URL=redis://redis:6379/0
ARQ_QUEUE_NAME=decision-matrix
JOBS_SYNC_FALLBACK=false
# If worker does not pick up a job within JOB_QUEUE_WATCHDOG_SECONDS (default 15s),
# the API process runs it in-process as a fallback (see job_queue.py).

# Autoroad network planner (network-planner package)
AUTOROAD_NETWORK_INPROCESS=true
# AUTOROAD_NETWORK_SERVICE_URL=http://network-planner:8080
# Prod VM image has SteinerPy only unless GEOSTEINER_BIN_DIR is mounted.
AUTOROAD_NETWORK_SOLVER=steinerpy
# AUTOROAD_NETWORK_SOLVER=geosteiner
# GEOSTEINER_BIN_DIR=/app/vendor/geosteiner/bin

# ЦМР / DEM (OpenTopography) — pad-earthwork, профиль линий (line-elevation-profile)
# See docs/deploy/pad-dem-storage.md
# OPENTOPOGRAPHY_API_KEY=change-me
# OPENTOPOGRAPHY_DEM_TYPE=COP30
# PAD_DEM_DATA_ROOT=/app/data/pad_dem

# AI Assistant (OpenRouter or other OpenAI-compatible API)
ASSISTANT_MCP_ENABLED=true
ASSISTANT_CHAT_ENABLED=true
ASSISTANT_LLM_BASE_URL=https://openrouter.ai/api/v1
ASSISTANT_LLM_API_KEY=change-me
# Do not use openrouter/free — it may route to nvidia/nemotron-3.5-content-safety (not chat).
ASSISTANT_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free
ASSISTANT_LLM_MAX_TOKENS=1024
# ASSISTANT_LLM_TIMEOUT_SECONDS=120
# ASSISTANT_CHAT_MAX_TOOL_ROUNDS=8
# ASSISTANT_CHAT_MAX_ROUTED_TOOLS=12
