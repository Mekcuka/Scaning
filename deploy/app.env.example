# Backend runtime environment for production container.
#
# Frontend build (GitHub Pages) — NOT in this file; set in repo Settings -> Actions -> Variables:
#   VITE_API_URL=https://your-api.example/api/v1
#   VITE_MAP_3D_ENABLED=true
#   VITE_MAPTILER_KEY=<MapTiler key for 3D terrain>
# See DEPLOY.md section 1 and decision-matrix/frontend/.env.example for local dev.
#
# Local Postgres+PostGIS on the same VM (deploy/docker-compose.yml service "db"):
DATABASE_URL=postgresql+asyncpg://sppr:change-me@db:5432/sppr
SECRET_KEY=change-me-in-production
ENVIRONMENT=production
DEMO_USERS_ENABLED=false
ALLOW_REGISTRATION=false
AUTH_RATE_LIMIT=10/minute
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://your-domain.example,https://your-user.github.io
ALGORITHM=HS256
COOKIE_SECURE=true
REDIS_URL=redis://redis:6379/0
ARQ_QUEUE_NAME=decision-matrix
JOBS_SYNC_FALLBACK=false

# Autoroad network planner (network-planner package)
AUTOROAD_NETWORK_INPROCESS=true
# AUTOROAD_NETWORK_SERVICE_URL=http://network-planner:8080
AUTOROAD_NETWORK_SOLVER=geosteiner
# GEOSTEINER_BIN_DIR=/app/vendor/geosteiner/bin
